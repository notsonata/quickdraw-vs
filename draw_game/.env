# Screen crop rectangle for the visible Canva canvas.
# Adjust these to match your monitor coordinates.
CANVAS_X=108
CANVAS_Y=212
CANVAS_W=593
CANVAS_H=594

# Runtime loop timing.
CLASSIFY_INTERVAL_SEC=0.25
ROUND_DURATION_SEC=0.00       # when set to 0.0, it uses the "round_active" flag to control round timing instead of a fixed duration. meaning no automatic round end.

# AI guessing rules.
AI_FIRST_GUESS_DELAY_SEC=0.0
AI_MIN_CONFIDENCE=0.05              # when set to 0.00, it randomly picks from the top N candidates instead of always picking the top1.
AI_STABLE_FOR_SEC=0.0
AI_SPEECH_COOLDOWN_SEC=0.0
MAX_AI_GUESSES_PER_ROUND=999
AI_SPEAK_EVERY_SCAN=true

# Optional local Gemma/PaliGemma vision arbiter.
GEMMA_ENABLED=false
GEMMA_MODEL=google/paligemma-3b-mix-224
GEMMA_INTERVAL_SEC=2.0
GEMMA_CONFIDENCE=0.9

# Classifier files.
# Allowed backends: tflite, onnx, stub.
# If model loading fails, the app uses StubClassifier.
MODEL_BACKEND=tflite
MODEL_PATH=draw_game/models/quickdraw-345-tflite/quickdraw_model.tflite
LABELS_PATH=draw_game/models/quickdraw-345-tflite/labels.txt
SELECTED_CATEGORIES_PATH=draw_game/models/selected_categories.txt  # if AI_MIN_CONFIDENCE is set to 0.00, it randomly picks from the top N candidates instead of always picking the top1. This file should contain the list of categories to consider for random selection, one category per line.
CLASSIFIER_INPUT_SIZE=28
MODEL_INPUT_W=28
MODEL_INPUT_H=28
MODEL_INPUT_CHANNELS=1
MODEL_BACKGROUND_VALUE=1.0
MODEL_STROKE_VALUE=0.0

# TTS.
TTS_ENABLED=true
KOKORO_VOICE=am_adam
KOKORO_SPEED=1.2
KOKORO_AUDIO_DEVICE=BlackHole

# Debugging.
DEBUG_SAVE_FRAMES=false
DEBUG_PRINT_JSON=true

CANVAS_SOURCE=web
WEB_CANVAS_HOST=127.0.0.1
WEB_CANVAS_PORT=8765
SELECTED_CATEGORIES_PATH=draw_game/models/selected_categories.txt
